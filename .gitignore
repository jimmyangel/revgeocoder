# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build artifacts (safe to delete anytime)
build/
dist/
public/regions/

# Natural Earth source files are large; ignore if you prefer not to commit them
data/natural_earth/*.json
data/natural_earth/*.shp
data/natural_earth/*.dbf
data/natural_earth/*.prj
data/natural_earth/*.shx

# Gen data
data/clean/

