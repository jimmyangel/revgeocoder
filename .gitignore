qgis/*.qgd
qgis/*.qgs~
qgis/.qgis2/
*.aux.xml

# macOS Finder noise
.DS_Store
.AppleDouble
.LSOverride

# macOS metadata in directories
**/.DS_Store

# VSCode / JetBrains / editor settings
.vscode/
.idea/

# Logs
*.log

# Temporary files
*.tmp
*.swp
*.swo

# Output tiles (generated)
public/regions/*.geojson

# Local environment files
.env
.env.local
.env.*.local
